{
  "@timestamp": {
    "$resolver": "timestamp",
    "pattern": {
      "format": "yyyy-MM-dd'T'HH:mm:ss.SSS'Z'",
      "timeZone": "UTC"
    }
  },
  "level": {
    "$resolver": "level",
    "field": "name"
  },
  "service": "order-service",
  "logger": {
    "$resolver": "logger",
    "field": "name"
  },
  "thread": {
    "$resolver": "thread",
    "field": "name"
  },
  "message": {
    "$resolver": "message",
    "stringified": true
  },
  "context": {
    "$resolver": "mdc"
  },
  "error": {
    "$resolver": "exception",
    "field": "className"
  },
  "error_message": {
    "$resolver": "exception",
    "field": "message"
  },
  "stack_trace": {
    "$resolver": "exception",
    "field": "stackTrace",
    "stringified": true
  }
}
